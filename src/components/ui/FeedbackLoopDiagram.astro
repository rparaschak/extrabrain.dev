<div class="not-prose my-6 flex justify-center">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 750 660" class="w-full max-w-2xl rounded-lg">
    <defs>
      <linearGradient id="flBg" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#0d1117"></stop>
        <stop offset="100%" stop-color="#161b22"></stop>
      </linearGradient>
      <filter id="flGlowPurple" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="4" result="blur"></feGaussianBlur>
        <feComposite in="SourceGraphic" in2="blur" operator="over"></feComposite>
      </filter>
      <filter id="flGlowGreen" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="4" result="blur"></feGaussianBlur>
        <feComposite in="SourceGraphic" in2="blur" operator="over"></feComposite>
      </filter>
      <filter id="flGlowAmber" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="4" result="blur"></feGaussianBlur>
        <feComposite in="SourceGraphic" in2="blur" operator="over"></feComposite>
      </filter>
      <marker
        id="flArrow"
        viewBox="0 0 10 10"
        refX="9"
        refY="5"
        markerWidth="6"
        markerHeight="6"
        orient="auto-start-reverse"
      >
        <path d="M 0 0 L 10 5 L 0 10 z" fill="#8b949e"></path>
      </marker>
      <marker
        id="flArrowAmber"
        viewBox="0 0 10 10"
        refX="9"
        refY="5"
        markerWidth="6"
        markerHeight="6"
        orient="auto-start-reverse"
      >
        <path d="M 0 0 L 10 5 L 0 10 z" fill="#fbbf24"></path>
      </marker>
      <marker
        id="flArrowGreen"
        viewBox="0 0 10 10"
        refX="9"
        refY="5"
        markerWidth="6"
        markerHeight="6"
        orient="auto-start-reverse"
      >
        <path d="M 0 0 L 10 5 L 0 10 z" fill="#86efac"></path>
      </marker>
      <marker
        id="flArrowPurple"
        viewBox="0 0 10 10"
        refX="9"
        refY="5"
        markerWidth="6"
        markerHeight="6"
        orient="auto-start-reverse"
      >
        <path d="M 0 0 L 10 5 L 0 10 z" fill="#c4b5fd"></path>
      </marker>
    </defs>

    <!-- Background -->
    <rect width="750" height="660" rx="8" fill="url(#flBg)"></rect>

    <!-- Subtle grid -->
    <g opacity="0.04" stroke="#c9d1d9" stroke-width="0.5">
      <line x1="0" y1="0" x2="0" y2="660"></line><line x1="60" y1="0" x2="60" y2="660"></line>
      <line x1="120" y1="0" x2="120" y2="660"></line><line x1="180" y1="0" x2="180" y2="660"></line>
      <line x1="240" y1="0" x2="240" y2="660"></line><line x1="300" y1="0" x2="300" y2="660"></line>
      <line x1="360" y1="0" x2="360" y2="660"></line><line x1="420" y1="0" x2="420" y2="660"></line>
      <line x1="480" y1="0" x2="480" y2="660"></line><line x1="540" y1="0" x2="540" y2="660"></line>
      <line x1="600" y1="0" x2="600" y2="660"></line><line x1="660" y1="0" x2="660" y2="660"></line>
      <line x1="720" y1="0" x2="720" y2="660"></line>
      <line x1="0" y1="0" x2="750" y2="0"></line><line x1="0" y1="60" x2="750" y2="60"></line>
      <line x1="0" y1="120" x2="750" y2="120"></line><line x1="0" y1="180" x2="750" y2="180"></line>
      <line x1="0" y1="240" x2="750" y2="240"></line><line x1="0" y1="300" x2="750" y2="300"></line>
      <line x1="0" y1="360" x2="750" y2="360"></line><line x1="0" y1="420" x2="750" y2="420"></line>
      <line x1="0" y1="480" x2="750" y2="480"></line><line x1="0" y1="540" x2="750" y2="540"></line>
      <line x1="0" y1="600" x2="750" y2="600"></line><line x1="0" y1="660" x2="750" y2="660"></line>
    </g>

    <!-- Decorative corners -->
    <g stroke="#30363d" stroke-width="1" fill="none" opacity="0.3">
      <polyline points="15,35 15,15 35,15"></polyline>
      <polyline points="715,15 735,15 735,35"></polyline>
      <polyline points="735,625 735,645 715,645"></polyline>
      <polyline points="35,645 15,645 15,625"></polyline>
    </g>

    <!-- ===== NODE 1: Me: Give prompt (purple stadium) ===== -->
    <rect
      x="370"
      y="30"
      width="200"
      height="42"
      rx="21"
      fill="#7c3aed"
      opacity="0.12"
      stroke="#7c3aed"
      stroke-width="1.5"
      filter="url(#flGlowPurple)"></rect>
    <text
      x="470"
      y="56"
      text-anchor="middle"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="13"
      font-weight="600"
      fill="#c4b5fd">Me: Give prompt</text
    >

    <!-- Arrow 1→2 -->
    <line x1="470" y1="72" x2="470" y2="96" stroke="#8b949e" stroke-width="1.5" marker-end="url(#flArrow)"></line>

    <!-- ===== NODE 2: Agent executes assignment (purple rect) ===== -->
    <rect
      x="335"
      y="100"
      width="270"
      height="42"
      rx="6"
      fill="#7c3aed"
      opacity="0.1"
      stroke="#7c3aed"
      stroke-width="1.5"
      filter="url(#flGlowPurple)"></rect>
    <text
      x="470"
      y="126"
      text-anchor="middle"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="12"
      fill="#c4b5fd">Agent executes assignment</text
    >

    <!-- Arrow 2→D1 -->
    <line x1="470" y1="142" x2="470" y2="168" stroke="#8b949e" stroke-width="1.5" marker-end="url(#flArrow)"></line>

    <!-- ===== DIAMOND 1: Code builds? (center 470,195) ===== -->
    <polygon
      points="470,172 545,195 470,218 395,195"
      fill="#f59e0b"
      opacity="0.08"
      stroke="#f59e0b"
      stroke-width="1.5"
      filter="url(#flGlowAmber)"></polygon>
    <text
      x="470"
      y="199"
      text-anchor="middle"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="11"
      fill="#fbbf24">Code builds?</text
    >

    <!-- Pass label D1 -->
    <text
      x="480"
      y="236"
      text-anchor="start"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="10"
      font-weight="600"
      fill="#86efac">Pass</text
    >
    <!-- Arrow D1→D2 (pass) -->
    <line x1="470" y1="218" x2="470" y2="253" stroke="#86efac" stroke-width="1.5" marker-end="url(#flArrowGreen)"
    ></line>

    <!-- ===== DIAMOND 2: Style check passed? (center 470,280) ===== -->
    <polygon
      points="470,257 555,280 470,303 385,280"
      fill="#f59e0b"
      opacity="0.08"
      stroke="#f59e0b"
      stroke-width="1.5"
      filter="url(#flGlowAmber)"></polygon>
    <text
      x="470"
      y="276"
      text-anchor="middle"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="10"
      fill="#fbbf24">Style check</text
    >
    <text
      x="470"
      y="289"
      text-anchor="middle"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="10"
      fill="#fbbf24">passed?</text
    >

    <!-- Pass label D2 -->
    <text
      x="480"
      y="321"
      text-anchor="start"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="10"
      font-weight="600"
      fill="#86efac">Pass</text
    >
    <!-- Arrow D2→D3 (pass) -->
    <line x1="470" y1="303" x2="470" y2="338" stroke="#86efac" stroke-width="1.5" marker-end="url(#flArrowGreen)"
    ></line>

    <!-- ===== DIAMOND 3: Complexity check OK? (center 470,365) ===== -->
    <polygon
      points="470,342 560,365 470,388 380,365"
      fill="#f59e0b"
      opacity="0.08"
      stroke="#f59e0b"
      stroke-width="1.5"
      filter="url(#flGlowAmber)"></polygon>
    <text
      x="470"
      y="361"
      text-anchor="middle"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="10"
      fill="#fbbf24">Complexity</text
    >
    <text
      x="470"
      y="374"
      text-anchor="middle"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="10"
      fill="#fbbf24">check OK?</text
    >

    <!-- Pass label D3 -->
    <text
      x="480"
      y="406"
      text-anchor="start"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="10"
      font-weight="600"
      fill="#86efac">Pass</text
    >
    <!-- Arrow D3→D4 (pass) -->
    <line x1="470" y1="388" x2="470" y2="423" stroke="#86efac" stroke-width="1.5" marker-end="url(#flArrowGreen)"
    ></line>

    <!-- ===== DIAMOND 4: AI review passed? (center 470,450) ===== -->
    <polygon
      points="470,427 555,450 470,473 385,450"
      fill="#f59e0b"
      opacity="0.08"
      stroke="#f59e0b"
      stroke-width="1.5"
      filter="url(#flGlowAmber)"></polygon>
    <text
      x="470"
      y="446"
      text-anchor="middle"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="10"
      fill="#fbbf24">AI review</text
    >
    <text
      x="470"
      y="459"
      text-anchor="middle"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="10"
      fill="#fbbf24">passed?</text
    >

    <!-- Pass label D4 -->
    <text
      x="480"
      y="491"
      text-anchor="start"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="10"
      font-weight="600"
      fill="#86efac">Pass</text
    >
    <!-- Arrow D4→D5 (pass) -->
    <line x1="470" y1="473" x2="470" y2="508" stroke="#86efac" stroke-width="1.5" marker-end="url(#flArrowGreen)"
    ></line>

    <!-- ===== DIAMOND 5: Tests passed? (center 470,535) ===== -->
    <polygon
      points="470,512 550,535 470,558 390,535"
      fill="#f59e0b"
      opacity="0.08"
      stroke="#f59e0b"
      stroke-width="1.5"
      filter="url(#flGlowAmber)"></polygon>
    <text
      x="470"
      y="539"
      text-anchor="middle"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="11"
      fill="#fbbf24">Tests passed?</text
    >

    <!-- Pass label D5 -->
    <text
      x="480"
      y="576"
      text-anchor="start"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="10"
      font-weight="600"
      fill="#86efac">Pass</text
    >
    <!-- Arrow D5→Done (pass) -->
    <line x1="470" y1="558" x2="470" y2="590" stroke="#86efac" stroke-width="1.5" marker-end="url(#flArrowGreen)"
    ></line>

    <!-- ===== NODE: Assignment done (green stadium) ===== -->
    <rect
      x="370"
      y="594"
      width="200"
      height="42"
      rx="21"
      fill="#22c55e"
      opacity="0.12"
      stroke="#22c55e"
      stroke-width="1.5"
      filter="url(#flGlowGreen)"></rect>
    <text
      x="470"
      y="620"
      text-anchor="middle"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="13"
      font-weight="600"
      fill="#86efac">Assignment done</text
    >

    <!-- ===== LEFT BOX: Result fed back to agent (amber, centered at y=365) ===== -->
    <rect
      x="105"
      y="344"
      width="240"
      height="42"
      rx="6"
      fill="#f59e0b"
      opacity="0.08"
      stroke="#f59e0b"
      stroke-width="1.5"
      filter="url(#flGlowAmber)"></rect>
    <text
      x="225"
      y="370"
      text-anchor="middle"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="12"
      fill="#fbbf24">Result fed back to agent</text
    >

    <!-- ===== FAIL PATHS ===== -->

    <!-- FAIL D1 (Code builds, y=195): L-shape left to x=225, down to box top -->
    <text
      x="370"
      y="188"
      text-anchor="end"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="10"
      font-weight="600"
      fill="#fbbf24">Fail</text
    >
    <path
      d="M 395,195 L 225,195 L 225,340"
      fill="none"
      stroke="#fbbf24"
      stroke-width="1.5"
      marker-end="url(#flArrowAmber)"></path>

    <!-- FAIL D2 (Style check, y=280): L-shape left to x=225, down to box top -->
    <text
      x="360"
      y="273"
      text-anchor="end"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="10"
      font-weight="600"
      fill="#fbbf24">Fail</text
    >
    <path
      d="M 385,280 L 225,280 L 225,340"
      fill="none"
      stroke="#fbbf24"
      stroke-width="1.5"
      marker-end="url(#flArrowAmber)"></path>

    <!-- FAIL D3 (Complexity, y=365): straight left into right side of box -->
    <text
      x="355"
      y="358"
      text-anchor="end"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="10"
      font-weight="600"
      fill="#fbbf24">Fail</text
    >
    <line x1="380" y1="365" x2="349" y2="365" stroke="#fbbf24" stroke-width="1.5" marker-end="url(#flArrowAmber)"
    ></line>

    <!-- FAIL D4 (AI review, y=450): L-shape left to x=225, up to box bottom -->
    <text
      x="360"
      y="443"
      text-anchor="end"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="10"
      font-weight="600"
      fill="#fbbf24">Fail</text
    >
    <path
      d="M 385,450 L 225,450 L 225,390"
      fill="none"
      stroke="#fbbf24"
      stroke-width="1.5"
      marker-end="url(#flArrowAmber)"></path>

    <!-- FAIL D5 (Tests, y=535): L-shape left to x=225, up to box bottom -->
    <text
      x="365"
      y="528"
      text-anchor="end"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="10"
      font-weight="600"
      fill="#fbbf24">Fail</text
    >
    <path
      d="M 390,535 L 225,535 L 225,390"
      fill="none"
      stroke="#fbbf24"
      stroke-width="1.5"
      marker-end="url(#flArrowAmber)"></path>

    <!-- ===== LOOP BACK: Result fed back → Agent executes assignment (dashed purple) ===== -->
    <path
      d="M 105,365 L 50,365 L 50,121 L 332,121"
      fill="none"
      stroke="#c4b5fd"
      stroke-width="1.5"
      stroke-dasharray="6 4"
      marker-end="url(#flArrowPurple)"></path>
  </svg>
</div>
