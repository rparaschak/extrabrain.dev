---

---

<div class="not-prose my-6 flex justify-center">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 700 200" class="w-full rounded-lg">
    <defs>
      <linearGradient id="cwBg" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#0d1117"></stop>
        <stop offset="100%" stop-color="#161b22"></stop>
      </linearGradient>
      <filter id="cwGlowGreen" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="3" result="blur"></feGaussianBlur>
        <feComposite in="SourceGraphic" in2="blur" operator="over"></feComposite>
      </filter>
      <filter id="cwGlowAmber" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="3" result="blur"></feGaussianBlur>
        <feComposite in="SourceGraphic" in2="blur" operator="over"></feComposite>
      </filter>
      <filter id="cwGlowRed" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="3" result="blur"></feGaussianBlur>
        <feComposite in="SourceGraphic" in2="blur" operator="over"></feComposite>
      </filter>
    </defs>

    <!-- Background -->
    <rect width="700" height="200" rx="8" fill="url(#cwBg)"></rect>

    <!-- Subtle grid -->
    <g opacity="0.04" stroke="#c9d1d9" stroke-width="0.5">
      <line x1="60" y1="0" x2="60" y2="200"></line>
      <line x1="120" y1="0" x2="120" y2="200"></line>
      <line x1="180" y1="0" x2="180" y2="200"></line>
      <line x1="240" y1="0" x2="240" y2="200"></line>
      <line x1="300" y1="0" x2="300" y2="200"></line>
      <line x1="360" y1="0" x2="360" y2="200"></line>
      <line x1="420" y1="0" x2="420" y2="200"></line>
      <line x1="480" y1="0" x2="480" y2="200"></line>
      <line x1="540" y1="0" x2="540" y2="200"></line>
      <line x1="600" y1="0" x2="600" y2="200"></line>
      <line x1="660" y1="0" x2="660" y2="200"></line>
    </g>

    <!-- Decorative corners -->
    <g stroke="#30363d" stroke-width="1" fill="none" opacity="0.3">
      <polyline points="15,35 15,15 35,15"></polyline>
      <polyline points="665,15 685,15 685,35"></polyline>
      <polyline points="685,165 685,185 665,185"></polyline>
      <polyline points="35,185 15,185 15,165"></polyline>
    </g>

    <!-- Title -->
    <text
      x="350"
      y="42"
      text-anchor="middle"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="16"
      font-weight="700"
      fill="#e6edf3">THE 75% RULE</text
    >

    <!-- Bar dimensions: x=50, width=600, y=70, height=56 -->
    <!-- 0-100K = 50% = 300px (x: 50 to 350) -->
    <!-- 100K-150K = 25% = 150px (x: 350 to 500) -->
    <!-- 150K-200K = 25% = 150px (x: 500 to 650) -->

    <!-- Green zone: 0–100K (50%) -->
    <rect
      x="50"
      y="70"
      width="300"
      height="56"
      rx="6"
      fill="#22c55e"
      opacity="0.15"
      stroke="#22c55e"
      stroke-width="1.5"
      filter="url(#cwGlowGreen)"></rect>
    <text
      x="200"
      y="103"
      text-anchor="middle"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="13"
      font-weight="600"
      fill="#86efac">0–50% — High accuracy</text
    >

    <!-- Yellow zone: 100K–150K (25%) -->
    <rect
      x="350"
      y="70"
      width="150"
      height="56"
      rx="0"
      fill="#f59e0b"
      opacity="0.12"
      stroke="#f59e0b"
      stroke-width="1.5"
      filter="url(#cwGlowAmber)"></rect>
    <text
      x="425"
      y="103"
      text-anchor="middle"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="12"
      font-weight="600"
      fill="#fbbf24">50–75% — Wrap up</text
    >

    <!-- Red zone: 150K–200K (25%) -->
    <rect
      x="500"
      y="70"
      width="150"
      height="56"
      rx="0"
      fill="#ef4444"
      opacity="0.12"
      stroke="#ef4444"
      stroke-width="1.5"
      filter="url(#cwGlowRed)"></rect>
    <!-- Round only right corners by clipping -->
    <rect x="644" y="70" width="6" height="56" rx="6" fill="#ef4444" opacity="0.12"></rect>
    <text
      x="575"
      y="103"
      text-anchor="middle"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="12"
      font-weight="600"
      fill="#fca5a5">75%+ — Danger</text
    >

    <!-- Tick marks -->
    <line x1="50" y1="130" x2="50" y2="140" stroke="#8b949e" stroke-width="1"></line>
    <line x1="350" y1="130" x2="350" y2="140" stroke="#8b949e" stroke-width="1"></line>
    <line x1="500" y1="130" x2="500" y2="140" stroke="#8b949e" stroke-width="1"></line>
    <line x1="650" y1="130" x2="650" y2="140" stroke="#8b949e" stroke-width="1"></line>

    <!-- Labels -->
    <text
      x="50"
      y="158"
      text-anchor="middle"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="12"
      fill="#8b949e">0K</text
    >
    <text
      x="350"
      y="158"
      text-anchor="middle"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="12"
      fill="#8b949e">100K</text
    >
    <text
      x="500"
      y="158"
      text-anchor="middle"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="12"
      fill="#8b949e">150K</text
    >
    <text
      x="650"
      y="158"
      text-anchor="middle"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="12"
      fill="#8b949e">200K</text
    >
  </svg>
</div>
