---

---

<div class="not-prose my-6 flex justify-center">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 700 420" class="w-full max-w-2xl rounded-lg">
    <defs>
      <linearGradient id="arBg" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#0d1117"></stop>
        <stop offset="100%" stop-color="#161b22"></stop>
      </linearGradient>
      <filter id="arGlowPurple" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="3" result="blur"></feGaussianBlur>
        <feComposite in="SourceGraphic" in2="blur" operator="over"></feComposite>
      </filter>
      <filter id="arGlowGreen" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="3" result="blur"></feGaussianBlur>
        <feComposite in="SourceGraphic" in2="blur" operator="over"></feComposite>
      </filter>
      <filter id="arGlowAmber" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="3" result="blur"></feGaussianBlur>
        <feComposite in="SourceGraphic" in2="blur" operator="over"></feComposite>
      </filter>
      <filter id="arGlowCyan" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="3" result="blur"></feGaussianBlur>
        <feComposite in="SourceGraphic" in2="blur" operator="over"></feComposite>
      </filter>
      <marker
        id="arArrow"
        viewBox="0 0 10 10"
        refX="9"
        refY="5"
        markerWidth="6"
        markerHeight="6"
        orient="auto-start-reverse"
      >
        <path d="M 0 0 L 10 5 L 0 10 z" fill="#8b949e"></path>
      </marker>
      <marker
        id="arArrowAmber"
        viewBox="0 0 10 10"
        refX="9"
        refY="5"
        markerWidth="6"
        markerHeight="6"
        orient="auto-start-reverse"
      >
        <path d="M 0 0 L 10 5 L 0 10 z" fill="#fbbf24"></path>
      </marker>
      <marker
        id="arArrowGreen"
        viewBox="0 0 10 10"
        refX="9"
        refY="5"
        markerWidth="6"
        markerHeight="6"
        orient="auto-start-reverse"
      >
        <path d="M 0 0 L 10 5 L 0 10 z" fill="#86efac"></path>
      </marker>
      <marker
        id="arArrowPurple"
        viewBox="0 0 10 10"
        refX="9"
        refY="5"
        markerWidth="6"
        markerHeight="6"
        orient="auto-start-reverse"
      >
        <path d="M 0 0 L 10 5 L 0 10 z" fill="#c4b5fd"></path>
      </marker>
    </defs>

    <!-- Background -->
    <rect width="700" height="420" rx="8" fill="url(#arBg)"></rect>

    <!-- Subtle grid -->
    <g opacity="0.04" stroke="#c9d1d9" stroke-width="0.5">
      <line x1="60" y1="0" x2="60" y2="420"></line>
      <line x1="120" y1="0" x2="120" y2="420"></line>
      <line x1="180" y1="0" x2="180" y2="420"></line>
      <line x1="240" y1="0" x2="240" y2="420"></line>
      <line x1="300" y1="0" x2="300" y2="420"></line>
      <line x1="360" y1="0" x2="360" y2="420"></line>
      <line x1="420" y1="0" x2="420" y2="420"></line>
      <line x1="480" y1="0" x2="480" y2="420"></line>
      <line x1="540" y1="0" x2="540" y2="420"></line>
      <line x1="600" y1="0" x2="600" y2="420"></line>
      <line x1="660" y1="0" x2="660" y2="420"></line>
    </g>

    <!-- Decorative corners -->
    <g stroke="#30363d" stroke-width="1" fill="none" opacity="0.3">
      <polyline points="15,35 15,15 35,15"></polyline>
      <polyline points="665,15 685,15 685,35"></polyline>
      <polyline points="685,385 685,405 665,405"></polyline>
      <polyline points="35,405 15,405 15,385"></polyline>
    </g>

    <!-- ===== NODE 1: Task (stadium shape, top) ===== -->
    <rect
      x="260"
      y="28"
      width="180"
      height="40"
      rx="20"
      fill="#0ea5c1"
      opacity="0.12"
      stroke="#0ea5c1"
      stroke-width="1.5"
      filter="url(#arGlowCyan)"></rect>
    <text
      x="350"
      y="53"
      text-anchor="middle"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="13"
      font-weight="600"
      fill="#67e8f9">Task</text>

    <!-- Arrow: Task → Dev Agent -->
    <line x1="350" y1="68" x2="350" y2="96" stroke="#8b949e" stroke-width="1.5" marker-end="url(#arArrow)"></line>

    <!-- ===== NODE 2: Development Agent: Execution ===== -->
    <rect
      x="200"
      y="100"
      width="300"
      height="44"
      rx="6"
      fill="#7c3aed"
      opacity="0.1"
      stroke="#7c3aed"
      stroke-width="1.5"
      filter="url(#arGlowPurple)"></rect>
    <text
      x="350"
      y="118"
      text-anchor="middle"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="10"
      fill="#8b949e">Development Agent</text>
    <text
      x="350"
      y="134"
      text-anchor="middle"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="12"
      font-weight="600"
      fill="#c4b5fd">Execution</text>

    <!-- Arrow: Dev Agent → split point -->
    <line x1="350" y1="144" x2="350" y2="186" stroke="#8b949e" stroke-width="1.5"></line>

    <!-- Split into two branches -->
    <!-- Left branch line -->
    <path
      d="M 350,186 L 200,186 L 200,206"
      fill="none"
      stroke="#8b949e"
      stroke-width="1.5"
      marker-end="url(#arArrow)"></path>
    <!-- Right branch line -->
    <path
      d="M 350,186 L 500,186 L 500,206"
      fill="none"
      stroke="#8b949e"
      stroke-width="1.5"
      marker-end="url(#arArrow)"></path>

    <!-- ===== NODE 3a: Performance Review (left) ===== -->
    <rect
      x="88"
      y="210"
      width="224"
      height="44"
      rx="6"
      fill="#22c55e"
      opacity="0.1"
      stroke="#22c55e"
      stroke-width="1.5"
      filter="url(#arGlowGreen)"></rect>
    <text
      x="200"
      y="228"
      text-anchor="middle"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="10"
      fill="#8b949e">Reviewer Agent</text>
    <text
      x="200"
      y="244"
      text-anchor="middle"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="12"
      font-weight="600"
      fill="#86efac">Performance Review</text>

    <!-- ===== NODE 3b: Architecture Review (right) ===== -->
    <rect
      x="388"
      y="210"
      width="224"
      height="44"
      rx="6"
      fill="#22c55e"
      opacity="0.1"
      stroke="#22c55e"
      stroke-width="1.5"
      filter="url(#arGlowGreen)"></rect>
    <text
      x="500"
      y="228"
      text-anchor="middle"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="10"
      fill="#8b949e">Reviewer Agent</text>
    <text
      x="500"
      y="244"
      text-anchor="middle"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="12"
      font-weight="600"
      fill="#86efac">Architecture Review</text>

    <!-- Merge branches back -->
    <!-- Left branch down -->
    <path
      d="M 200,254 L 200,272 L 350,272"
      fill="none"
      stroke="#8b949e"
      stroke-width="1.5"></path>
    <!-- Right branch down -->
    <path
      d="M 500,254 L 500,272 L 350,272"
      fill="none"
      stroke="#8b949e"
      stroke-width="1.5"></path>

    <!-- Arrow: merge → decision -->
    <line x1="350" y1="272" x2="350" y2="292" stroke="#8b949e" stroke-width="1.5" marker-end="url(#arArrow)"></line>

    <!-- ===== NODE 4: Decision diamond ===== -->
    <polygon
      points="350,298 440,332 350,366 260,332"
      fill="#f59e0b"
      opacity="0.08"
      stroke="#f59e0b"
      stroke-width="1.5"
      filter="url(#arGlowAmber)"></polygon>
    <text
      x="350"
      y="336"
      text-anchor="middle"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="11"
      fill="#fbbf24">Findings?</text>

    <!-- ===== YES branch (left) ===== -->
    <path
      d="M 260,332 L 160,332 L 160,390 L 227,390"
      fill="none"
      stroke="#fbbf24"
      stroke-width="1.5"
      marker-end="url(#arArrowAmber)"></path>
    <text
      x="200"
      y="325"
      text-anchor="middle"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="11"
      font-weight="600"
      fill="#fbbf24">Yes</text>

    <!-- NODE 5: Fix Findings -->
    <rect
      x="230"
      y="376"
      width="240"
      height="30"
      rx="6"
      fill="#7c3aed"
      opacity="0.1"
      stroke="#7c3aed"
      stroke-width="1.5"
      filter="url(#arGlowPurple)"></rect>
    <text
      x="350"
      y="396"
      text-anchor="middle"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="11"
      font-weight="600"
      fill="#c4b5fd">Dev Agent: Fix findings</text>

    <!-- Dashed arrow: Fix Findings → Done -->
    <path
      d="M 470,391 L 624,391 L 624,353"
      fill="none"
      stroke="#c4b5fd"
      stroke-width="1.5"
      stroke-dasharray="6 4"
      marker-end="url(#arArrowPurple)"></path>

    <!-- ===== NO branch (right) — done ===== -->
    <path
      d="M 440,332 L 570,332"
      fill="none"
      stroke="#86efac"
      stroke-width="1.5"
      marker-end="url(#arArrowGreen)"></path>
    <text
      x="490"
      y="325"
      text-anchor="middle"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="11"
      font-weight="600"
      fill="#86efac">No</text>

    <!-- NODE 6: Done (stadium) -->
    <rect
      x="574"
      y="314"
      width="100"
      height="36"
      rx="18"
      fill="#22c55e"
      opacity="0.12"
      stroke="#22c55e"
      stroke-width="1.5"
      filter="url(#arGlowGreen)"></rect>
    <text
      x="624"
      y="337"
      text-anchor="middle"
      font-family="'SF Mono','Fira Code','Consolas',monospace"
      font-size="13"
      font-weight="600"
      fill="#86efac">Done</text>
  </svg>
</div>
