---
import Layout from '~/layouts/PageLayout.astro';
import PlaybookLayout from '~/components/playbook/PlaybookLayout.astro';
import { fetchPlaybookPages, getIntroductionPage, getPlaybookNavigation } from '~/utils/playbook';
import { playbookSidebar } from '~/data/playbook/sidebar';

export const prerender = true;

const page = await getIntroductionPage();
if (!page) {
  return Astro.redirect('/404');
}

const allPages = await fetchPlaybookPages();
const { prev, next } = getPlaybookNavigation(page.section, page.slug, allPages);

const metadata = {
  title: page.title,
  description: page.description,
};
---

<Layout metadata={metadata}>
  <PlaybookLayout page={page} sections={playbookSidebar} allPages={allPages} prev={prev} next={next}>
    {page.Content && <page.Content />}
  </PlaybookLayout>
</Layout>
